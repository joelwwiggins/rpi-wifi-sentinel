# MINIMAL PRODUCTION CAPLET - only API and recon settings. Interface is set on command line (-iface wlan1mon).
# This eliminates "wifi.interface not set or not found" error in v2.33.0.

set api.rest on
set api.rest.address 0.0.0.0
set api.rest.port 8081

wifi.recon.channel clear
wifi.recon on
ble.recon on
net.probe on
net.recon on

print "MINIMAL PRODUCTION CAPLET LOADED - wlan1mon set via command line. API on 8081. Garage monitoring active."
