# Production clean caplet for RPi WiFi Sentinel (USB wlan1mon + stable management)
# Validated for bettercap v2.33.0 - no legacy -api, no duplicate recon

set api.rest on
set api.rest.address 0.0.0.0
set api.rest.port 8081

set wifi.interface wlan1mon

wifi.recon.channel clear
wifi.recon on
ble.recon on
net.probe on
net.recon on

print "WiFi Sentinel PRODUCTION loaded - wlan1mon for recon, API on 8081. Management wlan0 protected."
