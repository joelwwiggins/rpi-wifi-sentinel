# FINAL PRODUCTION CAPLET - Minimal for v2.33.0 on RPi with USB RTL8812AU in garage
# Interface is set via command line (-iface wlan1mon). No set wifi.interface in caplet to avoid "not set or not found" error.

set api.rest on
set api.rest.address 0.0.0.0
set api.rest.port 8081

wifi.recon.channel clear
wifi.recon on
ble.recon on
net.probe on
net.recon on

print "FINAL PRODUCTION CAPLET LOADED - wlan1mon set via command line. API on 8081. Garage monitoring active. No restart loop."
